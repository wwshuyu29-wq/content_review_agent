{
  "rules": [
    {
      "rule_id": "TEST-COUNT-001",
      "scope": {"content_type": "TECH_MEDIA_REVIEW", "fields": ["title", "body"]},
      "matcher": "count_consistency",
      "title_pattern": "(\\d+)\\s*[个项]?测试",
      "severity": "HIGH",
      "action": "HUMAN_REVIEW",
      "auto_fixable": false,
      "source_reference": ["CLAIM-001"]
    },
    {
      "rule_id": "TEST-EVIDENCE-001",
      "scope": {"content_type": "TECH_MEDIA_REVIEW", "field": "body"},
      "matcher": "evidence_required",
      "trigger_terms": ["亲测", "实测", "自用"],
      "required_fields": ["test_cases", "evidence"],
      "severity": "HIGH",
      "action": "HUMAN_REVIEW",
      "auto_fixable": false,
      "source_reference": ["CLAIM-001"]
    },
    {
      "rule_id": "CLAIM-PENDING-001",
      "scope": {"content_type": "TECH_MEDIA_REVIEW", "field": "body"},
      "matcher": "exact_phrase",
      "phrases": ["可以自动筛选、比较酒店并判断最划算"],
      "severity": "HIGH",
      "action": "HUMAN_REVIEW",
      "auto_fixable": false,
      "source_reference": ["PENDING-002"]
    }
  ]
}

{
  "rules": [
    {
      "rule_id": "TEST-COUNT-001",
      "scope": {"content_type": "TECH_MEDIA_REVIEW", "fields": ["title", "body"]},
      "matcher": "count_consistency",
      "title_pattern": "(\\d+)\\s*[个项]?测试",
      "severity": "HIGH",
      "action": "HUMAN_REVIEW",
      "auto_fixable": false,
      "source_reference": ["test_credibility.md"]
    },
    {
      "rule_id": "TEST-EVIDENCE-001",
      "scope": {"content_type": "TECH_MEDIA_REVIEW", "fields": ["title", "body"]},
      "matcher": "evidence_required",
      "trigger_terms": ["亲测", "实测", "自用"],
      "required_fields": ["test_cases", "evidence"],
      "required_test_case_fields": ["evidence_asset_ids", "app_version", "tested_at", "device", "operating_system", "network_environment"],
      "severity": "HIGH",
      "action": "HUMAN_REVIEW",
      "auto_fixable": false,
      "source_reference": ["test_credibility.md"]
    },
    {
      "rule_id": "CLAIM-UNSUPPORTED-ABSOLUTE-001",
      "scope": {"content_type": "TECH_MEDIA_REVIEW", "fields": ["title", "body"]},
      "matcher": "guarded_claim",
      "phrases": ["全赢", "天花板", "行业第一", "全网第一", "唯一选择", "绝对领先"],
      "subject_terms": ["路线", "行程", "需求", "场景", "能力", "规划"],
      "quantifier_terms": ["任何", "所有", "全部", "再复杂", "越复杂", "都"],
      "capability_terms": ["能", "可以", "支持", "搞定", "处理", "领先", "准确"],
      "percentage_context_terms": ["准确率", "成功率", "支持率", "保证", "保障"],
      "negation_terms": ["不", "没", "无", "并非", "不能", "未"],
      "criticism_terms": ["缺少依据", "不建议", "夸大", "这种说法", "所谓"],
      "severity": "MEDIUM",
      "action": "REQUIRE_TEXT_FIX",
      "auto_fixable": false,
      "source_reference": ["compliance.md", "content_quality.md"]
    },
    {
      "rule_id": "CLAIM-PENDING-001",
      "scope": {"content_type": "TECH_MEDIA_REVIEW", "fields": ["title", "body"]},
      "matcher": "hotel_capability",
      "hotel_terms": ["酒店", "住宿"],
      "capability_terms": ["订", "预订", "预约", "自动筛选", "筛选", "比较", "比价", "划算", "性价比", "排序", "推荐"],
      "unambiguous_capability_terms": ["自动筛选", "自动比较", "自动比", "智能比价"],
      "product_terms": ["小度想想", "助手", "产品", "它"],
      "assertion_terms": ["可以", "会", "能", "能够", "支持", "自动", "直接", "可"],
      "negation_terms": ["不", "没", "无", "并非", "不能", "未"],
      "criticism_terms": ["缺少依据", "不建议", "夸大", "这种说法", "所谓"],
      "severity": "HIGH",
      "action": "HUMAN_REVIEW",
      "auto_fixable": false,
      "source_reference": ["PENDING-002", "PENDING-004", "PENDING-005"]
    }
  ]
}

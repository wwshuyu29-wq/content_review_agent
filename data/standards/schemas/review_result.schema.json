{
  "$defs": {
    "AgentIssue": {
      "additionalProperties": false,
      "properties": {
        "rule_id": {
          "title": "Rule Id",
          "type": "string"
        },
        "category": {
          "title": "Category",
          "type": "string"
        },
        "severity": {
          "enum": [
            "LOW",
            "MEDIUM",
            "HIGH",
            "CRITICAL"
          ],
          "title": "Severity",
          "type": "string"
        },
        "field": {
          "title": "Field",
          "type": "string"
        },
        "evidence": {
          "$ref": "#/$defs/EvidenceSpan"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        },
        "suggestion": {
          "title": "Suggestion",
          "type": "string"
        },
        "source_reference": {
          "items": {
            "type": "string"
          },
          "title": "Source Reference",
          "type": "array"
        },
        "auto_fixable": {
          "title": "Auto Fixable",
          "type": "boolean"
        },
        "human_required": {
          "title": "Human Required",
          "type": "boolean"
        },
        "confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Confidence",
          "type": "number"
        }
      },
      "required": [
        "rule_id",
        "category",
        "severity",
        "field",
        "evidence",
        "reason",
        "suggestion",
        "source_reference",
        "auto_fixable",
        "human_required",
        "confidence"
      ],
      "title": "AgentIssue",
      "type": "object"
    },
    "EvidenceSpan": {
      "additionalProperties": false,
      "properties": {
        "quote": {
          "title": "Quote",
          "type": "string"
        },
        "start": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Start"
        },
        "end": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End"
        },
        "asset_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Asset Id"
        },
        "timestamp": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timestamp"
        }
      },
      "required": [
        "quote"
      ],
      "title": "EvidenceSpan",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "agent_id": {
      "enum": [
        "CONTENT_QUALITY",
        "COMPLIANCE",
        "BRAND",
        "PRODUCT_ACCURACY",
        "CAMPAIGN_EFFECTIVENESS"
      ],
      "title": "Agent Id",
      "type": "string"
    },
    "agent_version": {
      "title": "Agent Version",
      "type": "string"
    },
    "decision": {
      "enum": [
        "PASS",
        "PASS_WITH_SUGGESTIONS",
        "NEED_TEXT_FIX",
        "HUMAN_REVIEW",
        "BLOCK"
      ],
      "title": "Decision",
      "type": "string"
    },
    "summary": {
      "title": "Summary",
      "type": "string"
    },
    "score": {
      "anyOf": [
        {
          "maximum": 100,
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "title": "Score"
    },
    "confidence": {
      "maximum": 1,
      "minimum": 0,
      "title": "Confidence",
      "type": "number"
    },
    "issues": {
      "items": {
        "$ref": "#/$defs/AgentIssue"
      },
      "title": "Issues",
      "type": "array"
    }
  },
  "required": [
    "agent_id",
    "agent_version",
    "decision",
    "summary",
    "score",
    "confidence",
    "issues"
  ],
  "title": "AgentReviewResult",
  "type": "object"
}

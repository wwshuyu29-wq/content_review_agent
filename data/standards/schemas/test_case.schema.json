{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "test_case_id",
    "claim",
    "command",
    "observed_result",
    "evidence_asset_ids",
    "app_version",
    "tested_at",
    "device",
    "operating_system",
    "network_environment"
  ],
  "properties": {
    "test_case_id": {"type": "string", "minLength": 1},
    "claim": {"type": "string", "minLength": 1},
    "command": {"type": "string", "minLength": 1},
    "observed_result": {"type": "string", "minLength": 1},
    "evidence_asset_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "pattern": ".*\\S.*"}
    },
    "app_version": {"type": "string", "minLength": 1},
    "tested_at": {"type": "string", "minLength": 1},
    "device": {"type": "string", "minLength": 1},
    "operating_system": {"type": "string", "minLength": 1},
    "network_environment": {"type": "string", "minLength": 1}
  }
}
